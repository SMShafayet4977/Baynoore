# ── Dependencies ──────────────────────────────────────────────────
node_modules/
backend/node_modules/
frontend/node_modules/

# ── Environment files (NEVER commit real .env) ────────────────────
.env
.env.*
backend/.env
backend/.env.*
frontend/.env
frontend/.env.*

# Allow example files
!.env.example
!backend/.env.example
!frontend/.env.example

# ── Uploads / user-generated files ────────────────────────────────
backend/src/uploads/
backend/uploads/
uploads/

# ── Build outputs ──────────────────────────────────────────────────
dist/
frontend/dist/
build/
frontend/build/

# ── Logs ──────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── OS / Editor ───────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# ── Database dumps (keep .sql migration files) ────────────────────
*.sql.gz
*.dump
*.bak

# ── Misc ──────────────────────────────────────────────────────────
.cache/
.parcel-cache/
coverage/
.nyc_output/
